# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Anthropic (required for live LLM responses) ---
# Create a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model id (must exist for your API key — copy from Anthropic console or docs)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Max tokens for each completion (raise if replies truncate)
ANTHROPIC_MAX_TOKENS=1024

# --- App limits (see docs/API_CONTRACT.md) ---
MAX_MESSAGE_LENGTH=2000
MAX_SESSION_TURNS=10

# If the model returns empty reply_text, this string is used instead
EMPTY_REPLY_FALLBACK="I'm here with you."

# --- CORS (browser chat UI on another origin, e.g. Vercel) ---
# Comma-separated list, no spaces. Include local UI during dev.
MINDCARE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Process binding (not read by the app — pass to uvicorn yourself) ---
# Local:  uvicorn mindcare.main:app --host 0.0.0.0 --port 8000
# Render: set PORT in the dashboard; start command uses ${PORT}
